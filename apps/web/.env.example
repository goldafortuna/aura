# Supabase Postgres (pooler/connection string)
DATABASE_URL=

# Object Storage
# Default provider: cloudflare-r2
OBJECT_STORAGE_PROVIDER=cloudflare-r2
OBJECT_STORAGE_BUCKET=documents
LOCAL_OBJECT_STORAGE_DIR=.local-object-storage

# Cloudflare R2 (used when OBJECT_STORAGE_PROVIDER=cloudflare-r2)
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: if you expose R2 through a public/custom domain, signed URL can use it directly
R2_PUBLIC_BASE_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ======================
# AI Document Review (OpenAI-compatible / DeepSeek)
# ======================
# Default: DeepSeek OpenAI-compatible endpoint + model
AI_PROVIDER=openai_compatible
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat
AI_MAX_INPUT_CHARS=25000

# Optional: Upstash Redis for distributed rate limiting (recommended for multi-instance deploy)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
